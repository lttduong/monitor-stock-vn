# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=6651623374:AAGarzD5jD1jwAuGomcDb5vufWgcS3teiHo

# Telegram Chat ID (your personal chat or group chat ID)
# You can get this by messaging @userinfobot or @RawDataBot
TELEGRAM_CHAT_ID=-5175947373

# ── Watchlist ──────────────────────────────────────
# Comma-separated stock symbols to track
WATCHLIST=VCB,FPT,HPG,VNM,VHM,TCB,MWG,VPB,MBB,ACB

# ── Schedule (cron-style) ─────────────────────────
# Morning report at 8:30 AM (before market opens)
MORNING_REPORT_HOUR=8
MORNING_REPORT_MINUTE=30

# Midday report at 11:30 AM
MIDDAY_REPORT_HOUR=11
MIDDAY_REPORT_MINUTE=30

# Evening report at 15:30 PM (after market closes)
EVENING_REPORT_HOUR=15
EVENING_REPORT_MINUTE=30
